      "targets": [
        {
          "expr": "sum by (kafka_consumer_group_id) (kafka_consumer_fetch_manager_records_lag{kafka_consumer_group_id=~\"$consumer_group\"})",
          "legendFormat": "{{ kafka_consumer_group_id }}"
